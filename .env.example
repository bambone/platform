APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Плавающая JSON-панель отладки гида «Быстрый запуск» в кабинете тенанта (только при APP_DEBUG). По умолчанию выключена.
# FEATURE_TENANT_SITE_SETUP_GUIDED_DEBUG=true
# Только отладка: в Console на platform Filament лог fullscreen-слоёв, inert, наличие CSS .fi-modal-close-overlay (см. resources/js/platform-admin-overlay-diagnostics.js).
# DEBUG_FILAMENT_PLATFORM_OVERLAY=true
# Локально (как на проде по смыслу): маркетинг платформы на apex, тенант на поддомене того же «корня».
# APP_URL=http://rentbase.local
# PLATFORM_HOST=platform.rentbase.local
# TENANCY_CENTRAL_DOMAINS=rentbase.local,www.rentbase.local
# TENANCY_ROOT_DOMAIN=rentbase.local
# → лендинг платформы: http://rentbase.local/ , демо-тенант: http://motolevins.rentbase.local/ , консоль: http://platform.rentbase.local/ (логин /login, дашборд /dashboard)
# MotoLevinsTenantSeeder: general.domain = {scheme из APP_URL}://{slug}.{TENANCY_ROOT_DOMAIN} — отдельный env на тенанта не нужен.
# Не задавайте TENANT_DEFAULT_HOST равным apex из TENANCY_CENTRAL_DOMAINS — это хост маркетинга, не сайт клиента.
# Опционально: TENANT_DEFAULT_HOST= — лишний dev-хост в tenant_domains (например для особого сценария); можно не задавать.

APP_URL=http://localhost

# Отдельный хост для Filament Platform Console (локально: hosts / OSPanel, см. docs/operations/setup-access-deploy.md)
# PLATFORM_HOST=platform.rentbase.local

# Multi-tenant: маркетинговые хосты (через запятую), корень зоны для поддоменов тенантов, IP сервера, webroot для ACME, скрипт nginx/certbot
# TENANCY_CENTRAL_DOMAINS=rentbase.su,www.rentbase.su
# TENANCY_ROOT_DOMAIN=rentbase.su  → канонический поддомен тенанта: {slug}.rentbase.su в tenant_domains
# TENANCY_SERVER_IP=91.219.63.38
# TENANCY_CNAME_TARGET=domains.rentbase.su
# TENANCY_LE_WEBROOT=/var/www/letsencrypt
# TENANCY_PROVISION_SCRIPT=/usr/local/bin/rentbase-provision-domain
# TENANCY_PROVISION_USE_SUDO=false
# TENANCY_RESOLVER_CACHE_TTL=300
# TENANCY_LOG_VIEW_RESOLUTION=false  # true = лог выбора Blade-темы; не включается через APP_DEBUG

# Маркетинг платформы (central domains): куда слать заявки с /contact; пусто = MAIL_FROM_ADDRESS
# PLATFORM_MARKETING_CONTACT_TO=hello@rentbase.su
# Внешняя ссылка «Посмотреть демо» вместо /contact?intent=demo
# PLATFORM_MARKETING_DEMO_URL=
# Ссылки «Реальный проект» на маркетинговом лендинге (блок кейсов)
# PLATFORM_MARKETING_CASE_MOTOLEVINS=https://motolevins.rentbase.su
# PLATFORM_MARKETING_CASE_AFLYATUNOV=https://aflyatunov.rentbase.su
# PLATFORM_MARKETING_CASE_DEMENTIEV=https://dementiev.rentbase.su

# Язык приложения по умолчанию (в т.ч. <html lang> на публичных layout’ах через app()->getLocale()).
APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null

# Локально: трассировка быстрого сохранения linked-записи с карточки мото (EditMotorcycle). На проде false.
# SCHEDULING_TRACE_LINKED_MOTORCYCLE_SAVE=true
# Логи сохранения блоков карточки мото (config motorcycle.block_save_debug). На проде false.
# MOTORCYCLE_BLOCK_SAVE_DEBUG=true
LOG_LEVEL=debug

# Денежный слой тенанта: true = неизвестный binding в MoneyBindingRegistry бросает исключение (удобно для тестов/CI). На production обычно false — лог + fallback.
# MONEY_STRICT_BINDINGS=true

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Очереди: на сервере — database + воркер (systemd laravel-queue); локально можно sync.
QUEUE_CONNECTION=database

# На production при CACHE_STORE=file процесс PHP-FPM должен иметь запись в storage/framework/cache
# (см. docs/operations/setup-access-deploy.md#filament-storage-cache-permissions). Иначе — database или redis.
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Локально: log. На сервере (Postfix / sendmail): MAIL_MAILER=sendmail
MAIL_MAILER=log
# Путь к sendmail при MAIL_MAILER=sendmail (см. config/mail.php mailers.sendmail.path)
MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs -i"
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Лимит исходящих писем в минуту на одного клиента (tenant), если в карточке клиента не задано иное
MAIL_TENANT_PER_MINUTE=10

# --- Cloudflare R2 (S3-compatible API): один токен, два bucket ---
# См. docs/operations/r2-tenant-storage.md
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true
# Опционально: диск Laravel `s3` (config/filesystems.php); часто = приватный bucket
AWS_BUCKET=
# AWS_URL= только если используете disk `s3` с публичными URL

R2_PRIVATE_BUCKET=
R2_PUBLIC_BUCKET=
# Кастомный домен на public bucket или https://pub-xxxxx.r2.dev — для disk `r2-public` (->url())
R2_PUBLIC_URL=

# --- Tenant storage + Spatie ---
# Локальное зеркало 1:1 с R2 (dual write + delivery=local): см. docs/operations/tenant-media-local-mirror.md
# MEDIA_LOCAL_ROOT=/srv/rentbase-media
# TENANT_STORAGE_PUBLIC_DISK=tenant-public-mirror
# TENANT_MEDIA_WRITE_MODE_DEFAULT=dual
# TENANT_MEDIA_DELIVERY_MODE_DEFAULT=local
# TENANT_MEDIA_LOCAL_PUBLIC_BASE_PATH=/media
# TENANT_MEDIA_R2_PUBLIC_BASE_URL=https://media.example.com
TENANT_STORAGE_PUBLIC_DISK=r2-public
TENANT_STORAGE_PRIVATE_DISK=r2-private
MEDIA_DISK=r2-public
SEO_FILES_DISK=r2-private
# Опционально: база для TenantStorage::publicUrl, если CDN отдельно от R2_PUBLIC_URL
# TENANT_STORAGE_PUBLIC_CDN_URL=
# После замены файла под тем же ключом в R2 (immutable): смените значение или сделайте purge CDN
# TENANT_STORAGE_PUBLIC_URL_VERSION=v=20260411
# Обложки программ expert_auto из site/brand/hero.jpg и др. (false — только _system/program-covers)
# EXPERT_AUTO_COVERS_FROM_BRAND=true

# Миграция local → R2: docs/operations/r2-rollout-execution-checklist.md
# php artisan tenant-storage:migrate-to-r2 --dry-run --only=branding

# Поиск городов для справочника локаций (OpenStreetMap Nominatim, только с сервера)
# NOMINATIM_ENABLED=true
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# Реальный контакт для User-Agent (публичный Nominatim часто отдаёт 403 на *@example.com из MAIL_FROM_ADDRESS).
# Если не задано: неподходящий MAIL_FROM подменяется на geocoding@{хост из APP_URL}.
# NOMINATIM_CONTACT=ops@your-domain.example
# NOMINATIM_TIMEOUT=8
# NOMINATIM_SEARCH_CACHE_TTL=86400
# NOMINATIM_PICK_CACHE_TTL=86400

VITE_APP_NAME="${APP_NAME}"

# Тема витрины: после theme:prune-legacy-public (нет дубликатов в public/images/motolevins и public/themes/*)
# можно отключить legacy-префикс: THEME_LEGACY_ASSET_PREFIX=
# Важно: без опечатки — images/motolevins (с «s»), иначе 404 у старых путей в БД.
# Предустановленная тема в R2: php artisan theme:push-system-bundled
# Ключи: tenants/_system/themes/moto/… ; переопределения клиента: tenants/{id}/public/themes/…
# Пока не залили bundled в бакет на локали: THEME_SYSTEM_THEME_OBJECT_STORAGE=false
# THEME_SYSTEM_THEME_OBJECT_STORAGE=
# PLATFORM_DEFAULT_THEME_KEY=moto
